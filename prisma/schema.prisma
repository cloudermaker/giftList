generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Group {
  id            String    @id @default(uuid())
  name          String
  createdAt     DateTime? @default(now())
  updatedAt     DateTime? @updatedAt
  description   String?
  imageUrl      String?
  adminPassword String    @default("admin")
  users         User[]
}

model User {
  id                  String        @id @default(uuid())
  name                String
  createdAt           DateTime?     @default(now())
  groupId             String?
  updatedAt           DateTime?     @updatedAt
  acceptSuggestedGift Boolean       @default(false)
  isAdmin             Boolean       @default(false)
  takenGifts          Gift[]        @relation("takenUser")
  variants            GiftVariant[] @relation(name: "takenUser")
  gifts               Gift[]        @relation("user")
  group               Group?        @relation(fields: [groupId], references: [id])
}

model Gift {
  id              String    @id @default(uuid())
  name            String
  description     String?
  url             String?
  order           Int?
  userId          String?
  takenUserId     String?
  createdAt       DateTime? @default(now())
  updatedAt       DateTime? @updatedAt
  isSuggestedGift Boolean?  @default(false)
  takenUser       User?     @relation("takenUser", fields: [takenUserId], references: [id])
  user            User?     @relation("user", fields: [userId], references: [id])

  variants GiftVariant[]
}

model GiftVariant {
  id     String @id @default(uuid())
  giftId String
  gift   Gift   @relation(fields: [giftId], references: [id], onDelete: Cascade)

  label    String
  position Int

  takenUser   User?   @relation(fields: [takenUserId], references: [id], name: "takenUser")
  takenUserId String?

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([giftId])
}
